# Git
.git/
.gitignore

# Node modules (built inside Docker)
frontend/node_modules/
node_modules/

# Frontend build (built inside Docker)
frontend/dist/

# Python
__pycache__/
*.py[cod]
.venv/
.venv312/
venv/

# Test / coverage artifacts
.pytest_cache/
.coverage
coverage_html/

# Environment files
.env
.env.*

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store

# Service account (injected via Cloud Run)
service-account.json
*-firebase-adminsdk-*.json

